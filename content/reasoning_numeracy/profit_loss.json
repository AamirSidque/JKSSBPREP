        },
        {
          "type": "fact_card",
          "icon": "⚡",
          "title": "Shortcut 1 – CP from SP and P%",
          "content": "CP = SP × 100/(100+P%). Example: SP=110, P=10% → CP=100.",
          "highlight": true
        },
        {
          "type": "fact_card",
          "icon": "⚡",
          "title": "Shortcut 2 – Equivalent Discount",
          "content": "For two discounts: Equivalent = D₁ + D₂ – (D₁D₂)/100."
        },
        {
          "type": "fact_card",
          "icon": "⚡",
          "title": "Shortcut 3 – False Weight Profit",
          "content": "Profit% = (True – False)/False × 100."
        },
        {
          "type": "graph",
          "title": "Comparison of Shortcut Results",
          "graph_type": "horizontal",
          "unit": "%",
          "labels": ["CP formula", "Discount formula", "False weight formula"],
          "values": [25, 28, 11.11]
        },
        {
          "type": "mnemonic",
          "title": "Memory Trick",
          "mnemonic": "PCP",
          "memory_trick": "Profit = SP – CP; CP is base; Discount = MP – SP."
        },
        {
          "type": "revision",
          "title": "Shortcut Summary",
          "points": [
            "CP = SP × 100/(100±P/L%).",
            "Equivalent discount = D₁+D₂ – (D₁D₂)/100.",
            "False weight profit% = (True – False)/False × 100.",
            "Same SP with equal P/L% → loss% = (x²/100)%."
          ]
        }
      ]
    },
