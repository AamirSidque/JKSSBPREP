{
  "id": "profit_loss",
  "subject_id": "reasoning_numeracy",
  "title": "Profit and Loss",
  "subtopics": [
    {
      "id": "pl_basics",
      "title": "Basic Concepts – CP, SP, Profit, Loss",
      "estimated_minutes": 10,
      "blocks": [
        {
          "type": "hero",
          "title": "Profit and Loss",
          "subtitle": "Foundation of Business Mathematics",
          "tags": ["JKSSB", "High Weightage"]
        },
        {
          "type": "fact_card",
          "icon": "💰",
          "title": "Cost Price (CP)",
          "content": "The price at which an article is purchased. Includes overheads like transport, packaging, etc.",
          "highlight": true
        },
        {
          "type": "fact_card",
          "icon": "💵",
          "title": "Selling Price (SP)",
          "content": "The price at which an article is sold. Profit = SP – CP (if positive), Loss = CP – SP (if negative)."
        },
        {
          "type": "formula",
          "title": "Core Formulas",
          "formula": "Profit = SP – CP\nLoss = CP – SP\nProfit% = (Profit / CP) × 100\nLoss% = (Loss / CP) × 100",
          "description": "Profit and Loss percentages are always calculated on Cost Price."
        },
        {
          "type": "graph",
          "title": "CP vs SP Comparison",
          "graph_type": "bar",
          "unit": "₹",
          "labels": ["Item A", "Item B", "Item C", "Item D"],
          "values": [500, 600, 450, 700]
        },
        {
          "type": "solved_example",
          "title": "Example 1: Find Profit%",
          "given": ["CP = ₹500", "SP = ₹650"],
          "find": "Profit%",
          "steps": [
            "Profit = 650 – 500 = ₹150",
            "Profit% = (150/500) × 100 = 30%"
          ],
          "answer": "30%",
          "formula_used": "Profit% = (Profit/CP) × 100"
        },
        {
          "type": "solved_example",
          "title": "Example 2: Find Loss%",
          "given": ["CP = ₹800", "SP = ₹680"],
          "find": "Loss%",
          "steps": [
            "Loss = 800 – 680 = ₹120",
            "Loss% = (120/800) × 100 = 15%"
          ],
          "answer": "15%",
          "formula_used": "Loss% = (Loss/CP) × 100"
        },
        {
          "type": "comparison",
          "title": "Profit vs Loss",
          "left_header": "Profit",
          "right_header": "Loss",
          "rows": [
            { "left": "SP > CP", "right": "SP < CP" },
            { "left": "Profit = SP – CP", "right": "Loss = CP – SP" },
            { "left": "Profit% based on CP", "right": "Loss% based on CP" }
          ]
        },
        {
          "type": "revision",
          "title": "Key Points",
          "points": [
            "CP includes all expenses.",
            "Profit and Loss percentages are always based on CP.",
            "If SP is given with profit/loss%, CP = SP × 100/(100 ± P/L%)."
          ]
        }
      ]
    },
    {
      "id": "pl_formula_variations",
      "title": "Finding CP/SP from Percentages",
      "estimated_minutes": 10,
      "blocks": [
        {
          "type": "hero",
          "title": "Reverse Calculations",
          "subtitle": "Given Percentage, Find CP or SP",
          "tags": ["Important", "JKSSB"]
        },
        {
          "type": "fact_card",
          "icon": "📐",
          "title": "Key Relations",
          "content": "1. CP = SP × 100 / (100 + P%)\n2. CP = SP × 100 / (100 – L%)\n3. SP = CP × (100 + P%) / 100\n4. SP = CP × (100 – L%) / 100",
          "highlight": true
        },
        {
          "type": "solved_example",
          "title": "Example 1: Find CP when SP and Profit% given",
          "given": ["SP = ₹1320", "Profit% = 10%"],
          "find": "CP",
          "steps": ["CP = 1320 × 100 / (100+10) = 1320 × 100 / 110 = ₹1200"],
          "answer": "₹1200",
          "formula_used": "CP = SP × 100/(100+P%)"
        },
        {
          "type": "solved_example",
          "title": "Example 2: Find SP when CP and Loss% given",
          "given": ["CP = ₹2000", "Loss% = 12%"],
          "find": "SP",
          "steps": ["SP = 2000 × (100-12)/100 = 2000 × 88/100 = ₹1760"],
          "answer": "₹1760",
          "formula_used": "SP = CP × (100 – L%)/100"
        },
        {
          "type": "table",
          "title": "Quick Reference",
          "headers": ["Given", "Formula"],
          "rows": [
            ["SP, Profit%", "CP = SP × 100/(100+P%)"],
            ["SP, Loss%", "CP = SP × 100/(100–L%)"],
            ["CP, Profit%", "SP = CP × (100+P%)/100"],
            ["CP, Loss%", "SP = CP × (100–L%)/100"]
          ],
          "highlight_row": 0
        },
        {
          "type": "revision",
          "title": "Remember",
          "points": [
            "Profit% and Loss% are always on CP.",
            "Use the four formulas above to quickly solve reverse problems.",
            "Check by verifying: CP + Profit% of CP = SP."
          ]
        }
      ]
    },
    {
      "id": "pl_marked_discount",
      "title": "Marked Price and Discount",
      "estimated_minutes": 12,
      "blocks": [
        {
          "type": "hero",
          "title": "Marked Price & Discount",
          "subtitle": "Retail Pricing and Profit",
          "tags": ["High Weightage", "JKSSB"]
        },
        {
          "type": "fact_card",
          "icon": "🏷️",
          "title": "Definitions",
          "content": "Marked Price (MP) is the printed price. Discount is a reduction on MP. SP = MP – Discount.",
          "highlight": true
        },
        {
          "type": "formula",
          "title": "Discount Formulas",
          "formula": "Discount = MP × Discount%\nSP = MP × (100 – D%) / 100\nMP = SP × 100 / (100 – D%)",
          "description": "Discount% is always on MP."
        },
        {
          "type": "solved_example",
          "title": "Example: Find SP after discount",
          "given": ["MP = ₹1200", "Discount% = 20%"],
          "find": "SP",
          "steps": [
            "SP = 1200 × (100-20)/100 = 1200 × 80/100 = ₹960"
          ],
          "answer": "₹960",
          "formula_used": "SP = MP × (100 – D%)/100"
        },
        {
          "type": "graph",
          "title": "Comparison of MP, Discount, and SP",
          "graph_type": "horizontal",
          "unit": "₹",
          "labels": ["MP", "Discount", "SP"],
          "values": [1200, 240, 960]
        },
        {
          "type": "solved_example",
          "title": "Example: Find MP from CP, Profit%, Discount%",
          "given": ["CP = ₹800", "Profit% = 25%", "Discount% = 20%"],
          "find": "MP",
          "steps": [
            "SP = 800 × (100+25)/100 = 800 × 125/100 = ₹1000",
            "SP = MP × (100-20)/100 = MP × 0.8",
            "MP = 1000 / 0.8 = ₹1250"
          ],
          "answer": "₹1250",
          "formula_used": "Equate SP from CP and discount"
        },
        {
          "type": "exam_trap",
          "title": "Trap: Discount is on MP, not CP",
          "wrong": "Calculating discount on CP.",
          "correct": "Always apply discount on MP.",
          "tip": "Read the question – if it says 'marked price', discount is on that."
        },
        {
          "type": "revision",
          "title": "Key Points",
          "points": [
            "Discount is on MP.",
            "SP = MP × (100 – D%) / 100.",
            "When profit also exists, equate SP from CP and MP to find the other."
          ]
        }
      ]
    },
    {
      "id": "pl_successive_discounts",
      "title": "Successive Discounts",
      "estimated_minutes": 10,
      "blocks": [
        {
          "type": "hero",
          "title": "Successive Discounts",
          "subtitle": "Multiple Discounts in Sequence",
          "tags": ["Advanced", "JKSSB"]
        },
        {
          "type": "fact_card",
          "icon": "🔄",
          "title": "Concept",
          "content": "Successive discounts are not additive. The equivalent discount is less than the sum of individual discounts.",
          "highlight": true
        },
        {
          "type": "formula",
          "title": "Equivalent Discount",
          "formula": "For two discounts D₁ and D₂:\nEquivalent = D₁ + D₂ – (D₁ × D₂)/100",
          "description": "For more discounts, multiply (100 – D%) successively."
        },
        {
          "type": "solved_example",
          "title": "Example: 10% and 20% successive discounts",
          "given": ["D₁=10%, D₂=20%"],
          "find": "Single equivalent discount",
          "steps": [
            "Equivalent = 10+20 – (10×20)/100 = 30 – 2 = 28%"
          ],
          "answer": "28%",
          "formula_used": "D₁+D₂ – (D₁D₂)/100"
        },
        {
          "type": "graph",
          "title": "Effect of Successive Discounts",
          "graph_type": "line",
          "unit": "₹",
          "labels": ["Original", "After 10%", "After 20%"],
          "values": [1000, 900, 720]
        },
        {
          "type": "exam_trap",
          "title": "Trap: Adding discounts",
          "wrong": "10% + 20% = 30% (wrong).",
          "correct": "Equivalent = 28%.",
          "tip": "Always use the formula for successive discounts."
        },
        {
          "type": "revision",
          "title": "Key Points",
          "points": [
            "Successive discounts are not additive.",
            "Equivalent discount = D₁ + D₂ – (D₁D₂)/100.",
            "For more than two, apply stepwise or use product of (100 – D%)."
          ]
        }
      ]
    },
    {
      "id": "pl_false_weights",
      "title": "Profit/Loss with Dishonest Weights",
      "estimated_minutes": 8,
      "blocks": [
        {
          "type": "hero",
          "title": "False Weights",
          "subtitle": "When Scale is Tampered",
          "tags": ["Advanced", "JKSSB"]
        },
        {
          "type": "fact_card",
          "icon": "⚖️",
          "title": "Concept",
          "content": "A dishonest shopkeeper uses a false weight (e.g., 900g instead of 1kg) to earn profit without changing price.",
          "highlight": true
        },
        {
          "type": "formula",
          "title": "Profit% from False Weight",
          "formula": "Profit% = (True Weight – False Weight) / False Weight × 100",
          "description": "When selling at CP per unit weight."
        },
        {
          "type": "solved_example",
          "title": "Example: 900g instead of 1kg, sells at CP",
          "given": ["True = 1000g", "False = 900g"],
          "find": "Profit%",
          "steps": [
            "Profit% = (1000-900)/900 × 100 = (100/900)×100 ≈ 11.11%"
          ],
          "answer": "11.11%",
          "formula_used": "(True-False)/False × 100"
        },
        {
          "type": "solved_example",
          "title": "Example: With markup and false weight",
          "given": ["Markup = 20%", "False weight = 900g"],
          "find": "Overall profit%",
          "steps": [
            "Let CP per kg = 100. MP = 120 (for 1kg). He gives 900g.",
            "Cost for 900g = 100 × 900/1000 = 90.",
            "He sells for ₹120 → Profit = 30 → Profit% = (30/90)×100 = 33.33%"
          ],
          "answer": "33.33%",
          "formula_used": "Profit = (MP × True/False) – CP"
        },
        {
          "type": "revision",
          "title": "Key Points",
          "points": [
            "Profit from false weight = (True – False)/False × 100.",
            "If also mark up, combine: SP per unit ÷ (CP per unit × (False/True)).",
            "Always divide by false weight (what he actually paid for)."
          ]
        }
      ]
    },
    {
      "id": "pl_advanced_relations",
      "title": "Advanced Relations – Same SP/CP",
      "estimated_minutes": 10,
      "blocks": [
        {
          "type": "hero",
          "title": "Special Cases",
          "subtitle": "Two Items Sold at Same SP or Same CP",
          "tags": ["Advanced", "High Weightage"]
        },
        {
          "type": "fact_card",
          "icon": "🧩",
          "title": "Same SP with equal P% & L%",
          "content": "If two items are sold at the same SP, one at profit x% and other at loss x%, the overall loss% = (x²/100)%.",
          "highlight": true
        },
        {
          "type": "solved_example",
          "title": "Example: Same SP, 20% profit & 20% loss",
          "given": ["SP1 = SP2 = 1000", "P=20%, L=20%"],
          "find": "Overall loss%",
          "steps": [
            "CP1 = 1000×100/120 = 833.33, CP2 = 1000×100/80 = 1250.",
            "Total CP = 2083.33, Total SP = 2000.",
            "Loss = 83.33, Loss% = (83.33/2083.33)×100 ≈ 4%",
            "Using formula: (20²/100) = 4%."
          ],
          "answer": "Loss 4%",
          "formula_used": "Loss% = (x²/100)%"
        },
        {
          "type": "graph",
          "title": "Comparison of CP and SP",
          "graph_type": "bar",
          "unit": "₹",
          "labels": ["Item 1 (Profit)", "Item 2 (Loss)", "Overall"],
          "values": [1000, 1000, 2000]
        },
        {
          "type": "fact_card",
          "icon": "🧩",
          "title": "Same CP, different SP",
          "content": "If an item is sold at two different prices with different profit/loss percentages, find CP from one and then calculate the other SP."
        },
        {
          "type": "solved_example",
          "title": "Example: SP at 20% profit = 600, find SP for 30% profit",
          "given": ["SP1 = 600, P1=20%"],
          "find": "SP2 for P2=30%",
          "steps": [
            "CP = 600 × 100/120 = 500.",
            "SP2 = 500 × (100+30)/100 = 650."
          ],
          "answer": "₹650",
          "formula_used": "Find CP first."
        },
        {
          "type": "revision",
          "title": "Key Points",
          "points": [
            "Same SP with equal P/L% → loss% = (x²/100)%.",
            "Same CP → find CP from any SP and percentage.",
            "These patterns are common in exams."
          ]
        }
      ]
    },
    {
      "id": "pl_shortcuts",
      "title": "Shortcuts and Tricks",
      "estimated_minutes": 8,
      "blocks": [
        {
          "type": "hero",
          "title": "Profit & Loss Shortcuts",
          "subtitle": "Time-Saving Techniques",
