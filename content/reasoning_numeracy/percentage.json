{
  "id": "increase_decrease",
  "title": "Percentage Increase and Decrease",
  "estimated_minutes": 8,
  "blocks": [
    {
      "type": "hero",
      "title": "Percentage Change",
      "subtitle": "Increase and Decrease Problems",
      "tags": ["High Weightage"]
    },
    {
      "type": "formula",
      "title": "Percentage Increase",
      "formula": "((New Value - Original Value) / Original Value) × 100",
      "description": "Used when value increases."
    },
    {
      "type": "formula",
      "title": "Percentage Decrease",
      "formula": "((Original Value - New Value) / Original Value) × 100",
      "description": "Used when value decreases."
    },
    {
      "type": "solved_example",
      "title": "Solved Example",
      "given": [
        "Original Salary = 10000",
        "New Salary = 12500"
      ],
      "find": "Percentage Increase",
      "steps": [
        "Increase = 12500 - 10000 = 2500",
        "Percentage Increase = (2500/10000) × 100",
        "Percentage Increase = 25%"
      ],
      "answer": "25%",
      "formula_used": "Percentage Increase Formula"
    },
    {
      "type": "exam_trap",
      "title": "Common Mistake",
      "wrong": "Using new value in denominator.",
      "correct": "Always use original value in denominator.",
      "tip": "Very frequently asked concept."
    }
  ]
},

{
  "id": "successive_percentage",
  "title": "Successive Percentage Change",
  "estimated_minutes": 7,
  "blocks": [
    {
      "type": "hero",
      "title": "Successive Change",
      "subtitle": "Two Percentage Changes Together",
      "tags": ["Advanced"]
    },
    {
      "type": "formula",
      "title": "Net Change Formula",
      "formula": "a + b + (ab/100)",
      "description": "For two successive percentage increases."
    },
    {
      "type": "solved_example",
      "title": "Example",
      "given": [
        "Increase = 10%",
        "Increase Again = 20%"
      ],
      "find": "Net Increase",
      "steps": [
        "Net Change = 10 + 20 + (10×20)/100",
        "Net Change = 30 + 2",
        "Net Change = 32%"
      ],
      "answer": "32%",
      "formula_used": "Successive Percentage Formula"
    },
    {
      "type": "revision",
      "title": "Shortcut",
      "points": [
        "For increase use +ab/100.",
        "For opposite changes use -ab/100.",
        "Useful in Profit & Loss."
      ]
    }
  ]
},

