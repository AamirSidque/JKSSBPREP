    {
      "id": "ecosystem_meaning",
      "title": "Meaning, Definition & Concept of Ecosystem",
      "estimated_minutes": 6,
      "blocks": [
        {
          "type": "hero",
          "title": "Ecosystem",
          "subtitle": "Structural and Functional Unit of Nature",
          "tags": ["Ecology", "Very Important", "JKSSB"]
        },
        {
          "type": "fact_card",
          "icon": "📘",
          "title": "Definition",
          "content": "An ecosystem is a community of living organisms interacting with each other and with the surrounding non-living environment.",
          "highlight": true
        },
        {
          "type": "fact_card",
          "icon": "👨‍🔬",
          "title": "Important Scientist",
          "content": "The term Ecosystem was coined by A.G. Tansley in 1935."
        },
        {
          "type": "comparison",
          "title": "Basic Components",
          "left_header": "Biotic Components",
          "right_header": "Abiotic Components",
          "left_color": "#2ECC71",
          "right_color": "#3498DB",
          "rows": [
            {
              "left": "Plants",
              "right": "Air"
            },
            {
              "left": "Animals",
              "right": "Water"
            },
            {
              "left": "Bacteria",
              "right": "Temperature"
            },
            {
              "left": "Fungi",
              "right": "Soil"
            }
          ]
        },
        {
          "type": "exam_trap",
          "title": "⚠️ Common Exam Trap",
          "wrong": "Pond is the largest ecosystem",
          "correct": "Biosphere is the largest ecosystem while pond is the simplest self-sustaining ecosystem.",
          "tip": "Very commonly repeated in exams."
        },
        {
          "type": "revision",
          "title": "⚡ Quick Revision",
          "points": [
            "A.G. Tansley coined ecosystem term",
            "Biotic = Living",
            "Abiotic = Non-living",
            "Pond = Simplest ecosystem",
            "Biosphere = Largest ecosystem"
          ]
        }
      ]
    },
