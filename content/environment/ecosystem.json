        {
          "type": "fact_card",
          "icon": "🦌",
          "title": "Consumers",
          "content": "Consumers depend directly or indirectly on producers for food."
        },
        {
          "type": "fact_card",
          "icon": "🍄",
          "title": "Decomposers",
          "content": "Decomposers break down dead organic matter and recycle nutrients."
        },
        {
          "type": "exam_trap",
          "title": "⚠️ Common Exam Trap",
          "wrong": "Consumers produce their own food",
          "correct": "Only producers synthesize their own food.",
          "tip": "Basic but repeated MCQ."
        },
        {
          "type": "mnemonic",
          "title": "Biotic Components",
          "mnemonic": "PCD",
          "memory_trick": "Producers → Consumers → Decomposers",
          "color": "#27AE60"
        }
      ]
